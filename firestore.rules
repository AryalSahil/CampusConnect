rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isEmailVerified() {
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'minecraft782447@gmail.com' ||
        request.auth.token.email == 'sahil265064@gmail.com' ||
        request.auth.token.email == 'sahel265064@gmail.com'
      );
    }

    // Validation Blueprint for Users Profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
        && data.keys().size() == 5
        && data.uid is string && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 200
        && data.photoURL is string && data.photoURL.size() <= 1000;
    }

    // Validation Blueprint for Waitlist Entries
    function isValidWaitlist(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'collegeName', 'course', 'graduationYear', 'joinedAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 15
        && data.uid is string && (request.auth != null ? data.uid == request.auth.uid : true)
        && data.fullName is string && data.fullName.size() >= 1 && data.fullName.size() <= 150
        && data.email is string && data.email.size() <= 200 && data.email.matches('^[^@]+@[^@]+$')
        && data.collegeName is string && data.collegeName.size() >= 1 && data.collegeName.size() <= 200
        && data.course is string && data.course.size() >= 1 && data.course.size() <= 200
        && data.graduationYear is string && data.graduationYear.size() >= 1 && data.graduationYear.size() <= 15
        && (!data.keys().hasAny(['referralCode']) || data.referralCode == null || (data.referralCode is string && data.referralCode.size() <= 128))
        && (!data.keys().hasAny(['referrerUid']) || data.referrerUid == null || (data.referrerUid is string && data.referrerUid.size() <= 128))
        && (!data.keys().hasAny(['referralEmail']) || data.referralEmail == null || (data.referralEmail is string && data.referralEmail.size() <= 200))
        && (!data.keys().hasAny(['referralEmails']) || data.referralEmails == null || (data.referralEmails is list && data.referralEmails.size() <= 50))
        && (!data.keys().hasAny(['referralsCount']) || data.referralsCount == null || (data.referralsCount is int))
        && (!data.keys().hasAny(['status']) || data.status == null || (data.status is string))
        && (!data.keys().hasAny(['approvedAt']) || data.approvedAt == null || (data.approvedAt is timestamp));
    }

    // 3. Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isEmailVerified() && isValidId(userId) && isValidUser(request.resource.data)
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId) && isEmailVerified() && isValidId(userId) && isValidUser(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.uid == resource.data.uid;
    }

    match /waitlist/{waitlistId} {
      allow read: if true;
      allow create: if (
          (request.auth != null && isOwner(waitlistId) && isEmailVerified() && isValidId(waitlistId))
          || (request.auth == null && waitlistId == request.resource.data.uid)
        )
        && isValidWaitlist(request.resource.data)
        && request.resource.data.joinedAt == request.time
        || isAdmin()
        || (waitlistId == 'diagnostic_test_temp_doc' && isSignedIn());
      allow update: if (request.auth != null && (isOwner(waitlistId) || isAdmin()))
        || (request.auth == null && waitlistId == resource.data.uid)
        || (waitlistId == 'diagnostic_test_temp_doc' && isSignedIn());
      allow delete: if isAdmin() || (waitlistId == 'diagnostic_test_temp_doc' && isSignedIn());
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
